    {
      "id": "LYXErgwkFs0jnwGnaLxfw",
      "type": "text",
      "x": -1080.6973978013452,
      "y": 25955.870224778548,
      "width": 1023.7999877929688,
      "height": 855,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
